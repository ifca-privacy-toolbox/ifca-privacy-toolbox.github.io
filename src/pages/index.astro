---
import Base from '../layouts/Base.astro';
import ToolCard from '../components/ToolCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PublicationCard from '../components/PublicationCard.astro';

const tools = [
  {
    name: 'anjana',
    tagline: 'Data anonymization',
    description:
      'Apply nine anonymization techniques, from k-anonymity, l-diversity, t-closeness to β-likeness and δ-disclosure privacy among others to tabular datasets. Designed for privacy-compliant data sharing in research and industry.',
    tags: ['k-anonymity', 'l-diversity', 't-closeness', 'β-likeness', 'δ-disclosure privacy'],
    color: 'anjana' as const,
    icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
    repo: 'https://github.com/IFCA-Advanced-Computing/anjana',
    docs: 'https://anjana.readthedocs.io',
    pypi: 'https://pypi.org/project/anjana/',
    dashboardUrl: 'https://anjana.cloud.eosc-siesta.eu',
    demoUrl: 'https://www.youtube.com/watch?v=demo-anjana',
    featured: true,
  },
  {
    name: 'pyCANON',
    tagline: 'Privacy risk assessment',
    description:
      'Check and measure the level of anonymization of a tabular dataset. Compute the parameters related to the nine anonymziation techniques implemented in anjana. In addition, provides metrics for checking the privacy-utiloty trde-offs and the risks of re-identification and disclousre. It allows to audit your data before release.',
    tags: ['privacy audit', 'utiloty metrics', 'risk assessment', 're-identification risks', 'disclosure risks'],
    color: 'pycanon' as const,
    icon: 'M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11',
    repo: 'https://github.com/IFCA-Advanced-Computing/pycanon',
    docs: 'https://pycanon.readthedocs.io',
    pypi: 'https://pypi.org/project/pycanon/',
    dashboardUrl: 'https://pycanon.cloud.eosc-siesta.eu',
    featured: false,
  },
  {
    name: 'trasgoDP',
    tagline: 'Local differential privacy and metric privacy',
    description:
      'Apply local based-differential privacy mechanisms directlly to tabular, both numerical, categorical and location-based data (via geo-indistiguisability). It implementes a correlation loss metric and allwos to check the divergence. Designed for realeasing sanitized versions of the data with the privacy guarantees provided by the privacy budget.',
    tags: ['local DP', 'DP mechanims', 'privacy budget', 'metric privacy', 'geo-indistiguisability'],
    color: 'trasgodp' as const,
    icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
    repo: 'https://github.com/IFCA-Advanced-Computing/trasgodp',
    docs: 'https://trasgodp.readthedocs.io',
    pypi: 'https://pypi.org/project/trasgodp/',
    dashboardUrl: 'https://trasgodp.cloud.eosc-siesta.eu',
    featured: false,
  },
];

const projects = [
  {
    name: 'EOSC SIESTA',
    description: 'Secure Interactive Environments for SensiTive data Analytics. The SIESTA platform provides access to the interactive web application of the three tools, and these are also integrated in the SIESTA dashboard.',
    url: 'https://eosc-siesta.eu/',
    tools: ['anjana', 'pycanon', 'trasgodp'] as const,
    funder: 'EU Horizon Europe',
  },
  {
    name: 'AI4EOSC',
    description: 'Artificial Intelligence for the European Open Science Cloud. pyCANON was exploited for analyzing the impact of anonymization in the performance of machine learning models.',
    url: 'https://origin.ai4eosc.eu',
    tools: ['pycanon'] as const,
    funder: 'EU Horizon Europe',
  },
  {
    name: 'EOSC ARENA',
    description: 'AI Research Enhancement through Networked Agents. This toolkit will be integrated in the AI4EOSC catalog by EOSC ARENA for dedicated training in responsible use of AI and data privacy.',
    url: 'https://arena.ai4eosc.eu',
    tools: ['anjana', 'pycanon', 'trasgodp'] as const,
    funder: 'EU Horizon Europe',
  },
];

const publications = [
  {
    title: 'An Open Source Python Library for Anonymizing Sensitive Data',
    authors: 'Judith Sáinz-Pardo Díaz, Álvaro López García',
    venue: 'Scientific Data, vol. 11, no. 1, p. 1289',
    year: 2024,
    url: 'https://www.nature.com/articles/s41597-024-04019-z',
    tool: 'anjana',
  },
  {
    title: 'A Python Library to Check the Level of Anonymity of a Dataset',
    authors: 'Judith Sáinz-Pardo Díaz, Álvaro López García',
    venue: 'Scientific Data, vol. 9, no. 1, p. 785',
    year: 2022,
    url: 'https://www.nature.com/articles/s41597-022-01894-2',
    tool: 'pycanon',
  },
  {
    title: 'Comparison of Machine Learning Models Applied on Anonymized Data with Different Techniques',
    authors: 'Judith Sáinz-Pardo Díaz, Álvaro López García',
    venue: 'IEEE International Conference on Cyber Security and Resilience (CSR), Venice',
    year: 2023,
    url: 'https://ieeexplore.ieee.org/abstract/document/10224917',
    tool: 'pycanon',
  },
  {
    title: 'Privacy Preserving Machine Learning Workflow: from Anonymization to Personalized Differential Privacy Budgets in Federated Learning',
    authors: 'Judith Sáinz-Pardo Díaz, Álvaro López García',
    venue: 'arXiv preprint · Accepted at FLICS 2026',
    year: 2026,
    url: 'https://arxiv.org/abs/2605.02372',
    tool: 'anjana',
  },
];

const papersByOthers = [
  {
    title: 'Fair play for individuals, foul play for groups? Auditing anonymization’s impact on ML fairness',
    authors: 'Héber H. Arcolezi, Mina Alishahi, Adda-Akram Bendoukha, Nesrine Kaaniche',
    venue: '28th European Conference on Artificial Intelligence, Oct 2025, Bologna, Italy. pp.1009 - 1018',
    year: 2025,
    url: 'https://inria.hal.science/hal-05386310v1',
  },
  {
    title: 'Assessing synthetic data generation utility for cohort data secondary use',
    authors: 'Mattia Mazzoli, Janis Elfert, Paolo Sacerdoti, Marco Hirsch, Michael Davis Tira, Daniela Paolotti',
    venue: 'Preprint',
    year: 2025,
    url: 'https://www.medrxiv.org/content/10.1101/2025.06.09.25329247v1.full.pdf',
  },

];

const features = [
  {
    icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
    title: 'Standards-based',
    body: 'Implements well-known privacy models (from anonymity to DP) with a strong theoretical background.',
  },
  {
    icon: 'M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22',
    title: 'Open source',
    body: 'All code is available on GitHub under Apache 2.0. Auditable and reproducible.',
  },
  {
    icon: 'M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z',
    title: 'Well documented',
    body: 'Each tool has its own ReadTheDocs documentation with starting guideliness and usage examples.',
  },
  {
    icon: 'M18 20V10M12 20V4M6 20v-6',
    title: 'Research-grade',
    body: 'Built by researchers for researchers. Presented in peer-reviewed publications in high impact journals.',
  },
];
---

<Base>

  <!-- ── Hero ── -->
  <section class="hero section">
    <div class="container hero__inner">
      <div class="hero__label">
        <span class="badge badge--neutral">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          IFCA Privacy Toolbox
        </span>
      </div>

      <h1 class="hero__title">
        Privacy-preserving tools for handling sensitive data
      </h1>

      <p class="hero__lead">
        A suite of open-source Python libraries for data anonymization,
        local differential privacy, and privacy risk assessment.
        Developed at IFCA for researchers and data practitioners.
      </p>

      <div class="hero__ctas">
        <a href="#tools" class="btn btn--primary">Explore tools</a>
        <a
          href="https://github.com/IFCA-Advanced-Computing"
          class="btn btn--ghost"
          target="_blank"
          rel="noopener"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
          GitHub
        </a>
      </div>

      <div class="hero__install">
        <code id="install-command">pip install anjana pyCANON trasgoDP</code>
        <button id="copy-install" class="btn btn--ghost btn--copy" type="button">Copy</button>
      </div>
    </div>

    <div class="hero__background" aria-hidden="true">
      <div class="hero__bg-squares">
        <div class="hero__bg-square hero__bg-square--one"></div>
        <div class="hero__bg-square hero__bg-square--two"></div>
        <div class="hero__bg-square hero__bg-square--three"></div>
      </div>
    </div>
  </section>

  <hr class="divider" />

  <!-- ── Tools ── -->
  <section class="section" id="tools">
    <div class="container">
      <p class="label">The tools</p>
      <h2 class="section__title">Three libraries, three web applications</h2>
      <p class="section__sub">
        Each tool covers a different stage of the privacy pipeline.
        Use them independently or as a complete suite.
      </p>

      <div class="tools-grid">
        {tools.map(t => <ToolCard {...t} />)}
      </div>
    </div>
  </section>

  <!-- ── Pipeline diagram ── -->
  <section class="section section--subtle" id="features">
    <div class="container">
      <p class="label">How it fits together</p>
      <h2 class="section__title">A complete privacy pipeline</h2>
      <p class="section__sub">
        The three tools are designed to work in sequence,
        covering the full lifecycle of privacy-preserving data publishing.
      </p>

      <div class="pipeline">
        <div class="pipeline__step pipeline__step--anjana">
          <span class="pipeline__num">01</span>
          <strong>Anonymize or apply DP</strong>
          <span>Apply anonymization techniques with <code>anjana</code> or local-DP or metric-privacy with <code>trasgoDP</code></span>
        </div>
        <div class="pipeline__arrow" aria-hidden="true">→</div>
        <div class="pipeline__step pipeline__step--pycanon">
          <span class="pipeline__num">02</span>
          <strong>Verify the privacy level</strong>
          <span>DP provides mathematical guaranteen on the level of privacy, and you can check the level of anonymity using <code>pyCANON</code></span>
        </div>
        <div class="pipeline__arrow" aria-hidden="true">→</div>
        <div class="pipeline__step pipeline__step--neutral">
          <span class="pipeline__num">03</span>
          <strong>Check risks and utility</strong>
          <span>Check privacy-utility trade-off metrics, re-identification and disclosure risks using <code>pyCANON</code> or <code>trasgoDP</code>.</span>
        </div>
      </div>

      <!-- Key features grid -->
      <div class="features-grid">
        {features.map(f => (
          <div class="feature">
            <div class="feature__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d={f.icon} />
              </svg>
            </div>
            <h3 class="feature__title">{f.title}</h3>
            <p class="feature__body">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Projects ── -->
  <section class="section" id="projects">
    <div class="container">
      <p class="label">Used in</p>
      <h2 class="section__title">Research projects</h2>
      <p class="section__sub">
        These tools are actively used in scientific projects:
      </p>

      <div class="projects-grid">
        {projects.map(p => <ProjectCard {...p} />)}
      </div>
    </div>
  </section>

<!-- ── Publications ── -->
<section class="section section--subtle" id="publications">
  <div class="container">
    <p class="label">Publications</p>
    <h2 class="section__title">Related papers</h2>

    <p class="section__sub" style="margin-bottom: 1.5rem;">
      Peer-reviewed publications presenting the tools, methods and algorithms by the development team.
    </p>

    <div class="publications-grid">
      {publications.map(pub => <PublicationCard {...pub} />)}
    </div>

    <h3 class="pubs__subtitle">Papers exploiting the tools</h3>
    <p class="section__sub">
      Selected works by collaborators and associated projects that use the tools (for more third-party citations, refer to Google Scholar).
    </p>

    <div class="publications-grid">
      {papersByOthers.map(pub => <PublicationCard {...pub} />)}
    </div>
  </div>
</section>

  <!-- ── CTA strip ── -->
  <section class="cta-strip">
    <div class="container cta-strip__inner">
      <div>
        <h2 class="cta-strip__title">Ready to protect your data?</h2>
        <p class="cta-strip__sub">Install the tools, read the docs, or reach out to the team.</p>
      </div>
      <div class="cta-strip__actions">
        <a href="https://github.com/IFCA-Advanced-Computing" class="btn btn--primary" target="_blank" rel="noopener">Get started on GitHub</a>
        <a href="/contact" class="btn btn--ghost">Contact us</a>
      </div>
    </div>
  </section>

  <!-- ── About ── -->
  <section class="section section--subtle" id="about">
    <div class="container about">
      <div>
        <p class="label">About</p>
        <h2 class="section__title">Developed at IFCA</h2>
        <p>
          IFCA Privacy Toolbox is developed and maintained by the
          <a href="https://advancedcomputing.ifca.es" target="_blank" rel="noopener">
            Advanced Computing and e-Science Group
          </a>
          at the
          <a href="https://ifca.unican.es" target="_blank" rel="noopener">
            Institute of Physics of Cantabria (IFCA)
          </a>, a joint centre of CSIC and the University of Cantabria.
        </p>
        <p style="margin-top: 1rem; color: var(--color-text-muted); font-size: 0.9rem;">
          If you use these tools in your research, please cite the corresponding publications.
          See individual documentation pages for citation details.
        </p>
      </div>
      <div class="about__logos">
        <img src="/assets/logos/logo_IFCA.png" alt="IFCA logo" class="about__logo" />
        <img src="/assets/logos/logo_CSIC.png" alt="CSIC logo" class="about__logo" />
        <img src="/assets/logos/logo_UC.png" alt="University of Cantabria logo" class="about__logo" />
        <img src="/assets/logos/logo_MdM.png" alt="MDM logo" class="about__logo" />
      </div>
    </div>
  </section>

</Base>

<script>
  const copyButton = document.getElementById('copy-install');
  if (copyButton) {
    copyButton.addEventListener('click', async () => {
      const command = document.getElementById('install-command')?.textContent?.trim();
      if (!command) return;
      try {
        await navigator.clipboard.writeText(command);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.disabled = true;
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.disabled = false;
        }, 1600);
      } catch (err) {
        console.error(err);
      }
    });
  }

</script>
<script>
  const copyButton = document.getElementById('copy-install');
  if (copyButton) {
    copyButton.addEventListener('click', async () => {
      const command = document.getElementById('install-command')?.textContent?.trim();
      if (!command) return;
      try {
        await navigator.clipboard.writeText(command);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.disabled = true;
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.disabled = false;
        }, 1600);
      } catch (err) {
        console.error(err);
      }
    });
  }
</script>

<style>
/* Hero */
.hero {
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hero__inner {
  max-width: 680px;
  margin-inline: auto;
  position: relative;
  z-index: 1;
}
.hero__label { margin-bottom: 1.5rem; }
.hero__title {
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 500;
  letter-spacing: -0.03em;
  line-height: 1.15;
  margin-bottom: 1.25rem;
}
.hero__lead {
  font-size: 1.05rem;
  color: var(--color-text-muted);
  max-width: 540px;
  margin-inline: auto;
  margin-bottom: 2rem;
}
.hero__ctas {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 1.75rem;
}
.hero__install {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  background: var(--color-bg-muted);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0.8rem 1rem;
}
.hero__install code {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: var(--color-accent);
  white-space: nowrap;
}
.hero__install .btn--copy {
  padding: 0.45rem 0.9rem;
  font-size: 0.82rem;
}

.hero__background {
  position: absolute;
  inset: 0;
  pointer-events: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rem;
}
.hero__background {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(circle at 15% 15%, rgba(56, 189, 248, 0.16), transparent 30%),
    radial-gradient(circle at 80% 25%, rgba(37, 99, 235, 0.14), transparent 28%),
    linear-gradient(180deg, rgba(15, 23, 42, 0.03), rgba(15, 23, 42, 0.10));
}
.hero__bg-squares {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.hero__bg-square {
  position: absolute;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.14);
  box-shadow: 0 28px 40px rgba(15, 23, 42, 0.08);
  backdrop-filter: blur(10px);
  display: grid;
  place-items: center;
}
.hero__bg-square svg {
  width: 50%;
  height: 50%;
  stroke: rgba(255, 255, 255, 0.78);
  fill: none;
  stroke-width: 1.6;
}
.hero__bg-square--three svg {
  width: 56%;
  height: 56%;
  stroke: rgba(37, 99, 235, 0.72);
}
.hero__bg-square--one {
  width: 118px;
  height: 118px;
  top: 24%;
  left: 14%;
  transform: rotate(-6deg);
  animation: float-square-one 10s ease-in-out infinite;
}
.hero__bg-square--two {
  width: 108px;
  height: 108px;
  top: 42%;
  left: 48%;
  transform: translateX(-50%) rotate(4deg);
  animation: float-square-two 11s ease-in-out infinite;
}
.hero__bg-square--three {
  width: 96px;
  height: 96px;
  top: 18%;
  right: 14%;
  transform: rotate(8deg);
  animation: float-square-three 9.5s ease-in-out infinite;
}
@keyframes float-square-one {
  0%, 100% { transform: translateY(0) rotate(-6deg); }
  40% { transform: translateY(-8px) rotate(-6deg); }
  80% { transform: translateY(4px) rotate(-6deg); }
}
@keyframes float-square-two {
  0%, 100% { transform: translateX(-50%) translateY(0) rotate(4deg); }
  30% { transform: translateX(-50%) translateY(-10px) rotate(4deg); }
  60% { transform: translateX(-50%) translateY(5px) rotate(4deg); }
}
@keyframes float-square-three {
  0%, 100% { transform: translateY(0) rotate(8deg); }
  25% { transform: translateY(-6px) rotate(8deg); }
  55% { transform: translateY(3px) rotate(8deg); }
}
.hero__background::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 50% 15%, rgba(255, 255, 255, 0.14), transparent 24%);
}
@keyframes float {
  0%, 100% { transform: translateY(12px) rotate(-6deg); }
  50% { transform: translateY(-10px) rotate(-2deg); }
}
.hero__title {
  position: relative;
  z-index: 1;
}
.hero__lead,
.hero__ctas,
.hero__install {
  position: relative;
  z-index: 1;
}

/* Section headings */
.section__title {
  font-size: clamp(1.5rem, 3vw, 2rem);
  margin-bottom: 0.6rem;
}
.section__sub {
  font-size: 1rem;
  color: var(--color-text-muted);
  max-width: 560px;
  margin-bottom: 2.5rem;
  line-height: 1.7;
}

/* Tools grid */
.tools-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.25rem;
}

/* Pipeline */
.pipeline {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}
.pipeline__step {
  flex: 1;
  min-width: 200px;
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 1.25rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
.pipeline__step--anjana   { border-top: 3px solid var(--color-anjana); }
.pipeline__step--pycanon  { border-top: 3px solid var(--color-pycanon); }
.pipeline__step--neutral  { border-top: 3px solid var(--color-border-strong); }
.pipeline__num { font-size: 0.7rem; font-family: var(--font-mono); color: var(--color-text-faint); }
.pipeline__step strong { font-size: 0.95rem; font-weight: 500; }
.pipeline__step span { font-size: 0.83rem; color: var(--color-text-muted); }
.pipeline__step code {
  font-family: var(--font-mono);
  font-size: 0.78rem;
  background: var(--color-bg-muted);
  padding: 1px 5px;
  border-radius: 4px;
}
