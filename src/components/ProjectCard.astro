---
interface Props {
  name: string;
  description: string;
  url?: string;
  cordis?: string;
  dashboard?: string;
  tools: Array<'anjana' | 'pycanon' | 'trasgodp'>;
  funder?: string;
}

const { name, description, url, cordis, dashboard, tools, funder } = Astro.props;

const toolLabelMap = {
  anjana: 'anjana',
  pycanon: 'pyCANON',
  trasgodp: 'trasgoDP',
} as const;

const hasLinks = cordis || dashboard;
---

<article class="project-card">
  <div class="project-card__head">
    <h4 class="project-card__name">
      {url
        ? <a href={url} target="_blank" rel="noopener">{name} <span aria-hidden="true">↗</span></a>
        : name
      }
    </h4>
    {funder && <span class="project-card__funder">{funder}</span>}
  </div>
  <p class="project-card__desc">{description}</p>
  <div class="project-card__tools" aria-label="Tools used">
    {tools.map(t => <span class={`badge badge--${t}`}>{toolLabelMap[t]}</span>)}
  </div>
  {hasLinks && (
    <div class="project-card__links">
      {cordis && (
        <a href={cordis} class="project-card__link-btn" target="_blank" rel="noopener">
          CORDIS <span aria-hidden="true">↗</span>
        </a>
      )}
      {dashboard && (
        <a href={dashboard} class="project-card__link-btn" target="_blank" rel="noopener">
          Dashboard <span aria-hidden="true">↗</span>
        </a>
      )}
    </div>
  )}
</article>

<style>
.project-card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 1.25rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  transition: box-shadow 0.2s;
}
.project-card:hover { box-shadow: var(--shadow-sm); }

.project-card__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 0.75rem;
  flex-wrap: wrap;
}
.project-card__name {
  font-size: 0.95rem;
  font-weight: 500;
}
.project-card__name a { color: var(--color-accent); }
.project-card__funder {
  font-size: 0.75rem;
  color: var(--color-text-faint);
}
.project-card__desc {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.6;
}
.project-card__tools {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
}
.project-card__links {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-top: 0.25rem;
}
.project-card__link-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.78rem;
  font-weight: 500;
  color: var(--color-text-muted);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 0.3rem 0.65rem;
  text-decoration: none;
  transition: color 0.15s, border-color 0.15s;
}
.project-card__link-btn:hover {
  color: var(--color-accent);
  border-color: var(--color-accent);
}
</style>